{
  "version": 2,
  "builds": [
    {
      "src": "bestcallproj/bestcallproj/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "bestcallproj/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "bestcallproj/bestcallproj/wsgi.py"
    }
  ]
}